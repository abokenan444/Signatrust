  "homepage": "https://signatrust.net",
  "author": {
    "name": "Signatrust",
    "email": "partners@signatrust.net",
    "url": "https://signatrust.net"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abokenan444/Signatrust.git"
  },
  "bugs": {
    "url": "https://github.com/abokenan444/Signatrust/issues",
    "email": "partners@signatrust.net"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
